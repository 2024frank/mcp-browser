{
  "browser": {
    "browserName": "chromium",
    "launchOptions": {
      "headless": true,
      "args": [
        "--no-sandbox",
        "--disable-setuid-sandbox",
        "--disable-dev-shm-usage"
      ]
    },
    "contextOptions": {
      "viewport": {
        "width": 1280,
        "height": 800
      }
    }
  },
  "timeouts": {
    "action": 60000,
    "navigation": 60000
  }
}
